/*
const HDCONST_USPEVENT = HDCONST_BPSPAWNPOOLEVENT + 1;

class UrnSpawnPool : EventHandler {
	private Array<class <HDActor> > ValidItems;
	private bool Initialized;

	override void OnRegister() {
		// Ideally this should have the event handler run BEFORE any others.
		// Modders: Any event handlers meant to run at world load should have
		//          an order number of HDCONST_USPEVENT+1 or higher!
		//          (default is zero so this should almost never be a problem)
		SetOrder(HDCONST_USPEVENT);
		Initialized = false;
	}

	override void WorldLoaded(worldevent e) {
		BuildValidItemList();
	}

	private void BuildValidItemList() {
		if (ValidItems.Size() > 0) { return; } // don't rebuild
		Initialized = true;
		for (int i = 0; i < AllActorClasses.Size(); ++i) {
			let invitem = (class<HDActor>)(AllActorClasses[i]);
			if (!invitem) { continue; }
			AddItem(invitem);
		}
	}

	// Runs all normal checks and adds the passed item class to the spawn pool.
	//   Returns TRUE if the item class was successfully added.
	//   Returns FALSE if the item class could not be added.
	static bool AddItem(class<HDActor> cls) {
		UrnSpawnPool sp = UrnSpawnPool(EventHandler.Find("UrnSpawnPool"));
		if (!(sp && sp.Initialized)) {
            HDCore.Log('MiscMons', LOGGING_ERROR, "AddItem(): Urn spawn pool not found or initialized!");

			return false;
		 }

		if (CheckItem(cls) != -1) {
            HDCore.Log('MiscMons', LOGGING_WARN, cls.GetClassName().." already in Urn spawn pool");

			return false;
		}

		// All checks passed
		sp.ValidItems.Push(cls);

		HDCore.Log('MiscMons', LOGGING_DEBUG, "added "..cls.GetClassName().." to Urn spawn pool");

		return true;
	}

	// Removes an item class from the spawn pool if it exists.
	//   Returns TRUE if the item class was successfully removed.
	//   Returns FALSE if for some reason the removal failed
	static bool RemoveItem(class<HDActor> cls) {
		UrnSpawnPool sp = UrnSpawnPool(EventHandler.Find("UrnSpawnPool"));
		if (!(sp && sp.Initialized)) {
            HDCore.Log('MiscMons', LOGGING_ERROR, "RemoveItem(): Urn spawn pool not found or initialized!");
			
			return false;
		}

		int index = CheckItem(cls);
		if (index != -1) {
			sp.ValidItems.Delete(index);
            
			HDCore.Log('MiscMons', LOGGING_DEBUG, "removed "..cls.GetClassName().." from Urn spawn pool");

			return true;
		}

		return false;
	}

	// Checks if an item class already exists in the spawn pool
	//   Returns ARRAY INDEX if the item class is found in the spawn pool
	//   Returns -1 if the item class is not found in the spawn pool
	static int CheckItem(class<HDActor> cls) {
		UrnSpawnPool sp = UrnSpawnPool(EventHandler.Find("UrnSpawnPool"));
		if (!(sp && sp.Initialized)) {
            HDCore.Log('MiscMons', LOGGING_ERROR, "CheckItem(): Urn spawn pool not found or initialized!");
			
			return false;
		}

		for (int i=0; i<sp.ValidItems.Size(); i++) if (sp.ValidItems[i] is cls) return i;

		return -1;
	}

	// Returns a random valid item class from the Urn spawn pool.
	static class<HDActor> GetValidItem() {
		UrnSpawnPool sp = UrnSpawnPool(EventHandler.Find("UrnSpawnPool"));
		if (!(sp && sp.Initialized)) {
            HDCore.Log('MiscMons', LOGGING_ERROR, "GetValidItem(): Urn spawn pool not found or initialized!");
			
			return null;
		}

		if (sp.ValidItems.Size() <= 0) {
            HDCore.Log('MiscMons', LOGGING_WARN, "GetValidItem(): Urn spawn pool empty!");
			
			return null;
		}

		return sp.ValidItems[random(0, sp.ValidItems.Size() - 1)];
	}
}
*/

// Evil Eyes
class HDBlackEvilEye : EvilEye
{
    default
    {
        +forceybillboard
        +dontthrust
        +solid
        height 54;
        radius 16;
        projectilepassheight -16;
    }

    States
    {
        active:
	    inactive:
	    	BAYE A 0 A_SetScale(-Scale.X,1);
	    spawn:
	    	BAYE A 2 bright Light("HDCANDLE");
	    spawn2:
	    	BAYE A 0 A_Jump(256,1,2,3);
	    	BAYE A 1 bright Light("HDCANDLE") A_SetTics(random(2,50)); loop;
	    	BAYE B 1 bright Light("HDCANDLE") A_SetTics(random(2,20)); loop;
	    	BAYE C 1 bright Light("HDCANDLE") A_SetTics(random(2,20)); loop;
    }
}

