// Head Sticks
class MMHeadStickbase : HDActor
{
    default
    {
        radius 2;
        height 50;
        projectilepassheight -16;
        scale 0.75;
        +dontthrust
        +shootable
        +nodamage
        +noblood
        +forceybillboard
        +solid
    }

    states
    {
        spawn:
            POL2 A -1 nodelay A_SetScale((random(0,1)*2-1)*Scale.X,Scale.Y);
    }
}

class HDHeadStickEmpty : MMHeadStickbase
{
    states
    {
        spawn:
            CCPR D -1 nodelay A_SetScale((random(0,1)*2-1)*Scale.X,Scale.Y);
    }
}

