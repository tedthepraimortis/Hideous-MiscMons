            shotcount++;
        }
        ZYBR F 0 A_JumpIf(shotcount>50,"fireend");
        ZYBR # 0 A_JumpIfTargetInLOS("spray",90);
        goto fireend;

    spray2:
        ZYBR F 0{
            if(brontoshots<1){
            setstatelabel("fireend");}
        }
        ZYBR ZEZEZE 4 bright light("ROCKET"){
            if(brontoshots<1){
