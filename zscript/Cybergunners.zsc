    directshots:
        ZYBR F 0{
            if(brontoselected==1)
            {
                setstatelabel("directshots2");
            }
        }
        ZYBR FEFEFE 2 bright light("SPIDF"){
            A_StartSound("weapons/bigrifle",CHAN_WEAPON,CHANF_OVERLAP);
