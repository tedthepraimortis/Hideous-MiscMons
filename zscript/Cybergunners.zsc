            A_FaceTarget(12,12,0,0,FAF_MIDDLE);
        }
        ZYBR F 0 A_JumpIf(shotcount>50,"fireend");
        ZYBR # 0 A_JumpIfTargetInLOS("directshots",90);
        goto fireend;

    directshots2:
        ZYBR F 0{
            if(brontoshots<1){
            setstatelabel("fireend");}
        }
        ZYBR ZEZEZE 4 bright light("ROCKET"){
            if(brontoshots<1){
            setstatelabel("fireend");}else{
